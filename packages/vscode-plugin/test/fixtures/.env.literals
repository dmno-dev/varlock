# Test file for object/array literals (single & multi-line, with comments)

# Single-line array literal as a decorator value
# @dec=[a, b, c]
ARR_VAL=x

# Single-line object literal as a decorator value
# @sensitive={ preventLeaks=false }
OBJ_VAL=x

# Multi-line array passed as a function arg, with commented-out + trailing notes
# @import(./.env.shared, pick=[
#   ALPHA,
#   # BETA is disabled,
#   GAMMA, # primary
# ])
IMPORT_ML=x

# Multi-line object literal value
# @sensitive={
#   preventLeaks=false,
#   # enabled=false,
# }
OBJ_ML=x

# Nested literals
# @dec={ items=[1, 2], opts={ retry=true } }
NESTED=x

# Item-value array nested in a function call (plain-newline continuation, with comments)
LIST=fn([
  one,
  # two is disabled
  three, # primary
])

# Bare item-value literals (single-line only — bare multi-line literals are not
# valid @env-spec, they require a fn() wrapper)
BARE_ARR=[a, b, c]
BARE_OBJ={ host=localhost, port=5432 }
BARE_NESTED=[{ aa=1 }, { bb=2 }]
BARE_MIXED=[true, 123, "quoted", ${REF}, undefined]

# A bare unclosed bracket must NOT swallow the following entry (closes at EOL)
BARE_STRAY=[oops
AFTER_STRAY=ok

# Column-0 (unindented) comment inside an item-value fn-call literal — unlike a
# decorator, these lines are not # prefixed, so a column-0 # is a full comment
COL0_LITERAL=fn([
  ONE,
  # indented comment
# column-0 comment
  TWO, # trailing
])
