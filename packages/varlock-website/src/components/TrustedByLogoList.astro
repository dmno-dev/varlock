---
import LogoList, { type LogoItem } from "./LogoList.astro";

const trustedByLogos: LogoItem[] = [
  {
    title: "vlt.sh",
    icon: "vlt-logo-white",
    href: "https://vlt.sh",
  },
  {
    title: "Your Project",
    icon: "mdi:code-tags",
    href: "#",
  },
  {
    title: "Another Company",
    icon: "mdi:domain",
    href: "#",
  },
  {
    title: "Open Source Project",
    icon: "mdi:source-branch",
    href: "#",
  },
];
---

<div class="trusted-by-container">
  <LogoList title="Trusted by" logos={trustedByLogos} theme="orange" />
</div>

<style>
  .trusted-by-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin: 4rem 0;
  }

  .trusted-by-container :global(.logo-list ul) {
    grid-template-columns: repeat(4, 1fr);
  }

  @media (max-width: 768px) {
    .trusted-by-container {
      gap: 3rem;
    }

    .trusted-by-container :global(.logo-list ul) {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
