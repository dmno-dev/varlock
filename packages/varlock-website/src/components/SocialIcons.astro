---
import DefaultSocialIcons from "@astrojs/starlight/components/SocialIcons.astro";
import StarArrow from "./StarArrow.vue";
import bookIcon from "@/assets/pixel-art/book.png";
import scrollIcon from "@/assets/pixel-art/scroll.png";
---

<div class="custom-social-icons-wrapper">
  <a href="/getting-started/introduction" class="nav-link"><img src={bookIcon.src} width="26" height="27" alt="" class="pixel-nav-icon" /> Docs</a>
  <a href="/blog/" class="nav-link"><img src={scrollIcon.src} width="26" height="26" alt="" class="pixel-nav-icon" /> Blog</a>
  <div class="star-arrow-header">
    <StarArrow client:load />
  </div>
  <DefaultSocialIcons><slot /></DefaultSocialIcons>
</div>

<style>
  .custom-social-icons-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    position: relative;
  }
  .nav-link {
    color: var(--sl-color-white);
    text-decoration: none;
    font-family: var(--font-pixel);
    font-size: 1rem;
    padding: 0.25rem 0;
    margin-right: 0.75rem;
    transition: color 0.2s;
    white-space: nowrap;
    border: none !important;
    outline: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
  }
  .nav-link:hover {
    color: var(--sl-color-text-accent);
  }
  .pixel-nav-icon {
    vertical-align: middle;
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    margin-right: 0.15em;
    transition: transform 0.15s ease;
  }
  .nav-link:hover .pixel-nav-icon {
    transform: translateY(-2px);
  }
  .star-arrow-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    /* Position the arrow above the icons for visibility */
    margin-bottom: -0.5rem;
  }
  @media (max-width: 600px) {
    .custom-social-icons-wrapper {
      flex-direction: row;
      align-items: center;
      gap: 0.3rem;
    }
    .star-arrow-header {
      margin-bottom: 0;
      margin-right: 0;
    }
  }
</style>
