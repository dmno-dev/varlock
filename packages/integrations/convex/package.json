{
  "name": "@varlock/convex-integration",
  "description": "Varlock integration for syncing environment variables to Convex deployments",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/dmno-dev/varlock.git",
    "directory": "packages/integrations/convex"
  },
  "type": "module",
