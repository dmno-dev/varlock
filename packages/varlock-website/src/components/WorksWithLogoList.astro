---
import { Icon } from "astro-iconify";
import OpencodeLogo from "../custom-icons/opencode-logo.svg";
import cupboardTile from "../assets/pixel-art/inventory-cupboard-tile.png";
import { worksWithTilesForDisplay } from "../lib/works-with-tiles";
---

<div class="inventory-grid not-content">
  {
    worksWithTilesForDisplay().map(({ title, icon, customIcon, href }) => {
      const inner = (
        <div class="inventory-slot">
          <img src={cupboardTile.src} alt="" class="slot-bg" />
          <div class="slot-icon">
            {customIcon === "opencode" ? (
              <div class="custom-svg" role="img" aria-label={title}>
                <OpencodeLogo />
              </div>
            ) : (
              <Icon name={icon} aria-label={title} />
            )}
          </div>
          <span class="slot-label">{title}</span>
        </div>
      );

      if (href) {
        return (
          <a href={href} class="slot-link">
            {inner}
          </a>
        );
      }
      return inner;
    })
  }
</div>

<style>
  .inventory-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    gap: 4px;
    width: 100%;
    margin: 3rem auto;
    justify-items: stretch;
  }

  .slot-link {
    text-decoration: none;
    color: inherit;
  }

  .inventory-slot {
    position: relative;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .slot-bg {
    position: absolute;
    inset: 0;
    width: 72px;
    height: 72px;
    image-rendering: pixelated;
    pointer-events: none;
  }

  .slot-icon {
    position: relative;
    z-index: 1;
    width: 32px;
    height: 32px;
    color: #c8b89a;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.5));
    transition:
      color 150ms ease,
      transform 150ms ease,
      filter 150ms ease;
  }

  .slot-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .custom-svg {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-svg :global(svg) {
    width: 100%;
    height: 100%;
  }

  .custom-svg :global(path) {
    fill: currentColor;
  }

  .slot-label {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(50%);
    z-index: 2;
    background: rgba(0, 0, 0, 0.85);
    color: #e8dcc8;
    font-size: 0.7rem;
    line-height: 1.2;
    padding: 2px 6px;
    border-radius: 3px;
    border: 1px solid rgba(200, 184, 154, 0.3);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 150ms ease;
    font-family: monospace;
  }

  .slot-link:hover .slot-label,
  .slot-link:focus-visible .slot-label,
  .inventory-slot:hover .slot-label {
    opacity: 1;
  }

  .slot-link:hover .slot-icon,
  .slot-link:focus-visible .slot-icon {
    color: #f0d890;
    transform: scale(1.1);
    filter: drop-shadow(0 0 8px rgba(240, 216, 144, 0.4));
  }
</style>
