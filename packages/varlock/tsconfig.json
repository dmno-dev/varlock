{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    // "moduleResolution": "Node",
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "lib": ["ES2023"],
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "customConditions": ["ts-src"],
  },
  "include": [
    "src/**/*.ts",
    "**/*.ts",
  ],
  "exclude": [
    // this file declares a global `plugin` which the plugins depend on
    // but we dont want it declared everywhere
    "src/plugin-lib.ts",
    // must exclude dist or the DTS build picks up generated .d.ts files
    // via the **/*.ts include glob, causing duplicate global declarations
    "dist"
  ]
}
