{
  "$schema": "https://turbo.build/schema.json",
  // super annoying - turbo will swallow env vars unless we include them here
  // anything that would affect the build output needs to be included here
  // otherwise things that need to be passed through but do not affect caching should be in passThroughEnv
  "globalEnv": ["WORKERS_CI", "WORKERS_CI_*", "APP_ENV", "BUILD_TYPE"],
  "globalPassThroughEnv": [],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "package.json",
        "tsconfig.json",
        "tsconfig.*.json",
        "tsup.config.ts",
        "tsup-*.config.ts",
        "peggy.config.cjs",
        "astro.config.mjs",
        "astro.config.ts",
        "scripts/**",
        "src/**"
      ],
      "outputs": ["dist/**"]
    },
    "test:ci": {
      "dependsOn": ["^test:ci"],
      "inputs": ["package.json", "tsconfig.json", "tsconfig.*.json", "tsup.config.ts", "src/**", "test/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["package.json", "tsconfig.json", "tsconfig.*.json", "src/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
