---
import { Image } from "astro:assets";

import Layout from "../layouts/Layout.astro";
import { createMetaHead } from "../lib/meta";
import { LinkButton, Code } from "@astrojs/starlight/components";
import VarlockRetroBanner from "../components/VarlockRetroBanner.astro";
import WorksWithLogoList from "../components/WorksWithLogoList.astro";
import validationImg from "../assets/demo-images/failing-validation.png";
import intellisenseImg from "../assets/demo-images/intellisense.png";
import redactionImg from "../assets/demo-images/redaction.png";
import multiEnvImg from "../assets/demo-images/multi-env.png";
import externalProvidersImg from "../assets/demo-images/external-providers.png";
import EmailSignup from "../components/EmailSignup.vue";
import warlockStandingImg from "../assets/animation/warlock-standing.gif";
import warlockStrikeImg from "../assets/animation/warlock-strike.gif";

const site = Astro.site ?? new URL(Astro.url.origin);
const pageUrl = new URL(Astro.url.pathname, site).href;
const ogImageUrl = new URL("/og-images/index.png", site).href;
const pageTitle = "Varlock - AI-safe .env files";
const pageDescription =
  "AI-safe .env files: schemas for agents, secrets for humans. Validate, secure, and share environment variables with type-safety, leak prevention, and integrations for Next.js, Vite, Astro, and more.";
const metaHead = createMetaHead({
  title: pageTitle,
  description: pageDescription,
  url: pageUrl,
  ogImageUrl,
});
---

<Layout
  title={pageTitle}
  description={pageDescription}
  showSearch={false}
  head={metaHead}
>
  <main>
    <div class="container">
      <div class="homepage-hero not-content">
        <VarlockRetroBanner />
        <h1>
          <Image
            src={warlockStandingImg}
            alt="Varlock warlock"
          />
          <div>
            <span class="sparkle">AI-safe</span> .env files: <br />
            Schemas for agents, secrets for humans
          </div>
          <!-- <div>
            Environment variables with<br />the right amount of magic
          </div> -->
          <Image
            src={warlockStrikeImg}
            alt="Varlock warlock striking"
          />
        </h1>
      </div>
      <Code
        title=".env.schema"
        lang="env-spec"
        code=`
# Declarative schema — AI agents get full context, never secret values
# @sensitive @required @type=string(startsWith=sk-ant-api)
# @docs(https://platform.claude.com/docs/en/api/overview)
ANTHROPIC_API_KEY=

# @type=enum(development, preview, production, test)
APP_ENV=development # set non-sensitive default values directly

# use function calls and plugins to securely fetch data from external sources
XYZ_TOKEN=op("op://api-prod/xyz/auth-token")
    `
      />
      <p class="env-spec-example-note">
        Unlike <i>.env.example</i>, your <i>.env.schema</i> is a single source of
        truth, built for collaboration, that will never be out of sync. Agents can
        read your schema for full context — without accessing your secrets.
      </p>
      <Code
        title=".env.local (git-ignored)"
        lang="env-spec"
        code=`
# built-in encryption for local overrides - NOTHING in plaintext
ANTHROPIC_API_KEY=varlock(local:ABC123...)
      `
      />

      <div class="button-container">
        <LinkButton href="getting-started/introduction">Get Started</LinkButton>
        <LinkButton href="reference/item-decorators">Reference Docs</LinkButton>
      </div>
      <h2 style="justify-content: center;">
        <img
          src="https://varlock-pixel-art.dmno.workers.dev/effects/fire.gif"
        />
        Stay in the loop
      </h2>
      <EmailSignup client:load />
      <WorksWithLogoList />
      <div class="features-grid">
        <div class="text-only-card">
          <div>
            <h3>
              <img
                src="https://varlock-pixel-art.dmno.workers.dev/potions/6.gif"
              />
              AI-Safe Config
            </h3>
            <p>
              Your <code>.env.schema</code> is readable by AI agents — they get full
              context on your config without ever seeing secret values. Prevent leaks
              to AI servers by design.
            </p>
          </div>
        </div>
        <div class="text-only-card">
          <div>
            <h3>
              <img
                src="https://varlock-pixel-art.dmno.workers.dev/potions/5.gif"
              />
              Leak Scanning
            </h3>
            <p>
              Proactively scan your codebase for leaked secrets with <code
                >varlock scan</code
              >. Set up git hooks to catch leaks before they're committed.
            </p>
          </div>
        </div>
        <div>
          <div>
            <h3>
              <img
                src="https://varlock-pixel-art.dmno.workers.dev/potions/8.gif"
              />
              Runtime Protection
            </h3>
            <p>
              Redact sensitive values from logs and console output. Detect leaks
              in bundled client code and outgoing server responses at runtime.
            </p>
          </div>
          <Image
            src={redactionImg}
            alt="Redaction demo"
            class="img-with-border"
          />
        </div>
        <div>
          <div>
            <h3>
              <img
                src="https://varlock-pixel-art.dmno.workers.dev/potions/2.gif"
              />
              Validation
            </h3>
            <p>
              Powerful validation capabilities, without custom logic.
              Misconfiguration errors are surfaced much earlier in your
              development cycle, with clear error messages.
            </p>
          </div>
          <Image
            src={validationImg}
            alt="Validation demo"
            class="img-with-border"
          />
        </div>
        <div>
          <div>
            <h3>
              <img
                src="https://varlock-pixel-art.dmno.workers.dev/potions/7.gif"
              />
              Type-safety
            </h3>
            <p>
              Automatically generate types according to your schema - the single
              source of truth - instead of writing them by hand.
            </p>
          </div>
          <Image
            src={intellisenseImg}
            alt="IntelliSense demo"
            class="img-with-border"
          />
        </div>
        <div>
          <div>
            <h3>
              <img
                src="https://varlock-pixel-art.dmno.workers.dev/potions/4.gif"
              />
              Environments
            </h3>
            <p>
              Combine defaults, environment-specific .env files, local
              git-ignored overrides, and process env vars. Compose values
              together using functions.
            </p>
          </div>
          <Image
            src={multiEnvImg}
            alt="Multi-env demo"
            class="img-with-border"
          />
        </div>
        <div>
          <div>
            <h3>
              <img
                src="https://varlock-pixel-art.dmno.workers.dev/potions/1.gif"
              />
              Secure secrets
            </h3>
            <p>
              Load secrets from 6 provider plugins — 1Password, Infisical, AWS
              Secrets Manager, Azure Key Vault, Google Secret Manager, and
              Bitwarden — or any CLI tool.
            </p>
          </div>
          <Image
            src={externalProvidersImg}
            alt="External providers demo"
            class="img-with-border"
          />
        </div>
      </div>
      <!-- <SecretReveal client:load /> -->

      <div class="button-container">
        <LinkButton href="getting-started/introduction">Get Started</LinkButton>
        <LinkButton href="reference/item-decorators">Reference Docs</LinkButton>
      </div>

      <div class="button-container"></div>

      <h2>
        <img
          src="https://varlock-pixel-art.dmno.workers.dev/effects/fire.gif"
        />
        Installation
      </h2>
      <Code
        lang="bash"
        code=`
# Install as a dependency in a js project
npx varlock init

# OR install as standalone binary via homebrew
brew install dmno-dev/tap/varlock
# OR via cURL
curl -sSfL https://varlock.dev/install.sh | sh -s
    `
      />

      <h2>
        <img
          src="https://varlock-pixel-art.dmno.workers.dev/effects/fire.gif"
        />
        Drop-in replacement for dotenv
      </h2>

      <Code
        title="my-app.ts"
        lang="diff"
        meta="lang='ts'"
        code={`
- import 'dotenv/config';
+ import 'varlock/auto-load';

// *optional* type-safe env access
+ import { ENV } from 'varlock/env';
- const client = new AbcApi(process.env.ABC_API_KEY);
+ const client = new AbcApi(ENV.ABC_API_KEY);
`}
      />
      <p class="env-spec-example-note">
        <b>varlock</b> can be used as a direct replacement for <code
          >dotenv</code
        > in most projects. Just swap your import and get validation, security, and
        more. No other code changes required!
      </p>

      <h2>
        <img
          src="https://varlock-pixel-art.dmno.workers.dev/effects/fire.gif"
        />
        Run anywhere - with any language
      </h2>

      <Code lang="bash" code={`varlock run -- python my_script.py`} />
      <p class="env-spec-example-note">
        Use <code>varlock run</code> to inject resolved, validated env vars into another
        process.
      </p>

      <EmailSignup client:load />

      <div>
        <a
          href="https://osscar.dev/org/dmno-dev"
          target="_blank"
          rel="noopener noreferrer"
        >
          <img
            src="https://osscar.dev/api/badge?slug=dmno-dev"
            alt="Featured on OSSCAR"
          />
        </a>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1rem 1rem;
    gap: 2rem;
  }

  .button-container {
    display: flex;
    justify-content: center;
    gap: 1rem;
    a {
      display: block;
      text-align: center;
    }
  }

  .button-container > .sl-link-button {
    min-width: 25%;
    border: 2px solid transparent;
  }

  .button-container > .sl-link-button:hover {
    background-color: var(--sl-color-black);
    color: var(--sl-color-text-accent);
    border: 2px solid var(--sl-color-text-accent);
    animation: pixelate 1.25s infinite;
  }

  @keyframes pixelate {
    0% {
      border-style: solid;
    }
    25% {
      border-style: dotted;
    }
    50% {
      border-style: dashed;
    }
    75% {
      border-style: dotted;
    }
    100% {
      border-style: solid;
    }
  }

  .button-container > .sl-link-button::after {
    content: " →";
    margin-left: 0.25rem;
    white-space: nowrap;
  }

  h1 {
    text-align: center;
  }

  .tagline {
    text-decoration: underline;
    color: var(--brand-cyan);
  }

  .sparkle {
    /* color: var(--brand-purple--t1); */
    --sparkle-color: var(--brand-cyan);
    /* text-shadow: 0 0 2px var(--sparkle-color); */
    animation: sparkle-pulse 4s ease-in-out infinite;
  }
  :root[data-theme="light"] .sparkle {
    --sparkle-color: var(--brand-purple);
  }

  @keyframes sparkle-pulse {
    0% {
      text-shadow: 0 0 0px var(--sparkle-color);
    }
    50% {
      text-shadow:
        0 0 3px var(--color-text-full-shade-invert),
        0 0 15px var(--sparkle-color);
    }
    100% {
      text-shadow: 0 0 0px var(--sparkle-color);
    }
  }

  .description {
    margin-bottom: 2rem;
    font-size: 1.5rem;
  }

  .component-container {
    margin-bottom: 3rem;
  }

  /* Card styles */
  .card {
    border: 1px dotted var(--brand-purple--t1);
    position: relative;
    background: var(--sl-color-background);
    transition: transform 0.2s ease;
  }

  .card:hover {
    transform: translateY(-2px);
  }

  .card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 10px;
    height: 10px;
    border-top: 2px dotted var(--brand-purple--t1);
    border-left: 2px dotted var(--brand-purple--t1);
  }

  .card::after {
    content: "";
    position: absolute;
    bottom: 0;
    right: 0;
    width: 10px;
    height: 10px;
    border-bottom: 2px dotted var(--brand-purple--t1);
    border-right: 2px dotted var(--brand-purple--t1);
  }

  .card {
    border-bottom: 1px dotted var(--brand-purple--t1);
    padding: 1rem;
  }

  .card {
    padding: 1rem;
  }

  .card > .title {
    /* color: var(--brand-purple--text); */
    font-family: var(--font-pixel);
    font-weight: var(--font-pixel-weight);
    margin: 0;
  }

  .card ul {
    margin: 0;
    padding-left: 1.5rem;
  }

  .card li {
    margin-bottom: 0.5rem;
  }

  .card li:last-child {
    margin-bottom: 0;
  }

  .features-grid {
    > div {
      margin-top: 3rem;
      display: grid;
      grid-template-columns: 3fr 5fr;
      gap: 1rem;
      align-items: center;
      @media screen and (max-width: 700px) {
        grid-template-columns: 1fr;
      }
    }
    > div.text-only-card {
      grid-template-columns: 1fr;
      border: 1px dotted var(--brand-purple--t1);
      border-radius: 12px;
      padding: 1.5rem;
    }
    img {
      margin: 0;
    }
  }
  .homepage-hero {
    text-align: center;
    padding-bottom: 0.3em;
    h1 {
      margin: 0.5em 0;
      display: flex;
      gap: 1em;
      justify-content: center;
      align-items: flex-start;
      font-size: 32px;
      text-wrap: balance;

      @media screen and (max-width: 700px) {
        font-size: 24px;
        gap: 0em;
        flex-direction: column;
        align-items: center;
      }

      img {
        display: block;
        @media screen and (max-width: 700px) {
          &:first-child {
            display: none;
          }
        }
        flex-shrink: 0;
        margin-top: -30px;

        /* scale: 2; */
        &:first-child {
          /* transform: scaleX(-1); */
        }
        &:last-child {
          transform: scaleX(-1);
          margin-bottom: 8px;
        }
      }
    }
  }
  .env-spec-example-note {
    padding: 0 1em;
    text-align: center;
  }

  h2 {
    border: none !important;
    gap: 0.3em !important;
  }
</style>
