#
# @defaultRequired=infer @defaultSensitive=false
# ---

ITEM1=foo

# @type=simpleVaultEncryptionKey
SIMPLE_VAULT_ENCRYPTION_KEY=

# @sensitive
ENCRYPTED_ITEM=simpleVault(vault1, GAdBm3dAnsR2+KUBaBMwaQhN+tM8Tq8Bk/nEk74CHAJE0E+aUDAIDYtwc5k8lec=)


# @sensitive
OP_TOKEN=

OP1=op("op://dev test/example/credential")
OP2=op("op://dev test/example/staging")
OP3=op("op://dev test/example/production")