{
  "$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
  "changelog": ["@varlock/changeset-changelog", { "repo": "dmno-dev/varlock" }],
  "commit": false,
  "fixed": [],
  "linked": [],
  "ignore": ["@env-spec/utils", "varlock-docs-mcp", "@varlock/website"],
  "access": "public",
