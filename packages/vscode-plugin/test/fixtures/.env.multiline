# Test file for multi-line decorator function calls
# @import(
#   ./.env.base,
#   ITEM1,
#   ITEM2,
#   ITEM3,
# )
# ---

# Single-line decorator for comparison
# @required
SIMPLE_VAR=value

# Multi-line bare fn call
# @import(
#   ./other.env,
#   KEY1,
#   KEY2
# )
AFTER_MULTILINE=works

# Multi-line with function value
# @dec=someFn(
#   arg1,
#   arg2,
#   key=val
# )
WITH_FN_VALUE=test

# Multi-line item value function
MULTILINE_VALUE=concat(
  "hello",
  "world",
  "test"
)

# Multi-line item-value fn call with indented AND column-0 comments (no bracket
# literal — the body is plain continuation lines, so column-0 # is a comment)
FN_WITH_COMMENTS=fn(
  ONE,
  # indented comment
# column-0 comment
  TWO, # trailing note
)
AFTER_FN=ok

# Nested on next line
NEXT_ITEM=simple
