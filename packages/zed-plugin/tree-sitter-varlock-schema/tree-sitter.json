{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "env",
      "camelcase": "Env",
      "title": "Env",
      "scope": "source.env",
      "file-types": ["env", "env.schema"],
      "injection-regex": "^env$"
    }
  ],
  "metadata": {
    "version": "0.1.3",
    "license": "MIT",
    "description": "Tree-sitter grammar for dotenv and Varlock schema files"
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
