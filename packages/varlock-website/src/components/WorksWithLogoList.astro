---
import { Icon } from "astro-iconify";
import OpencodeLogo from "../custom-icons/opencode-logo.svg";
import cupboardTile from "../assets/pixel-art/inventory-cupboard-tile.png";

interface LogoItem {
  title: string;
  icon?: string;
  customIcon?: astroHTML.JSX.Element | ((_props: Record<string, any>) => any);
  href?: string;
}

const allLogos: LogoItem[] = [
  // AI Tools
  {
    title: "Claude Code",
    icon: "simple-icons:anthropic",
    href: "/guides/ai-tools/",
  },
  {
    title: "Cursor",
    icon: "simple-icons:cursor",
    href: "/guides/ai-tools/",
  },
  {
    title: "Gemini CLI",
    icon: "simple-icons:googlegemini",
    href: "/guides/ai-tools/",
  },
  {
    title: "Opencode",
    customIcon: OpencodeLogo,
    href: "/guides/ai-tools/",
  },
  // Plugins
  {
    title: "1Password",
    icon: "simple-icons:1password",
    href: "/plugins/1password/",
  },
  {
    title: "Infisical",
    icon: "mdi:infinity",
    href: "/plugins/infisical/",
  },
  {
    title: "AWS Secrets",
    icon: "simple-icons:amazonaws",
    href: "/plugins/aws-secrets/",
  },
  {
    title: "Azure Key Vault",
    icon: "simple-icons:microsoftazure",
    href: "/plugins/azure-key-vault/",
  },
  {
    title: "Google Secret Manager",
    icon: "simple-icons:googlecloud",
    href: "/plugins/google-secret-manager/",
  },
  {
    title: "Bitwarden",
    icon: "simple-icons:bitwarden",
    href: "/plugins/bitwarden/",
  },
  // Integrations
  {
    title: "Next.js",
    icon: "simple-icons:nextdotjs",
    href: "/integrations/nextjs/",
  },
  {
    title: "Vite",
    icon: "simple-icons:vite",
    href: "/integrations/vite/",
  },
  {
    title: "Astro",
    icon: "simple-icons:astro",
    href: "/integrations/astro/",
  },
  {
    title: "GitHub Actions",
    icon: "simple-icons:githubactions",
    href: "/integrations/github-action/",
  },
  {
    title: "Docker",
    icon: "simple-icons:docker",
    href: "/guides/docker/",
  },
  // Languages
  {
    title: "Node.js",
    icon: "simple-icons:nodedotjs",
    href: "/integrations/javascript/",
  },
  {
    title: "Bun",
    icon: "simple-icons:bun",
    href: "/integrations/bun/",
  },
  {
    title: "Python",
    icon: "simple-icons:python",
    href: "/integrations/other-languages/",
  },
  {
    title: "Ruby",
    icon: "simple-icons:ruby",
    href: "/integrations/other-languages/",
  },
  {
    title: "Go",
    icon: "simple-icons:go",
    href: "/integrations/other-languages/",
  },
  {
    title: "PHP",
    icon: "simple-icons:php",
    href: "/integrations/other-languages/",
  },
  // Extra
  {
    title: "Qwik",
    icon: "simple-icons:qwik",
    href: "/integrations/vite/#frameworks",
  },
  {
    title: "React Router",
    icon: "simple-icons:reactrouter",
    href: "/integrations/vite/#frameworks",
  },
  {
    title: "Cloudflare Workers",
    icon: "simple-icons:cloudflare",
    href: "/integrations/vite/#frameworks",
  },
  {
    title: "TypeScript",
    icon: "simple-icons:typescript",
    href: "/integrations/javascript/",
  },
];
---

<div class="inventory-grid not-content">
  {
    allLogos.map(({ title, icon, customIcon: CustomIcon, href }) => {
      const inner = (
        <div class="inventory-slot">
          <img src={cupboardTile.src} alt="" class="slot-bg" />
          <div class="slot-icon">
            {CustomIcon ? (
              <div class="custom-svg" role="img" aria-label={title}>
                <CustomIcon />
              </div>
            ) : (
              <Icon name={icon} aria-label={title} />
            )}
          </div>
          <span class="slot-label">{title}</span>
        </div>
      );

      if (href) {
        return (
          <a href={href} class="slot-link">
            {inner}
          </a>
        );
      }
      return inner;
    })
  }
</div>

<style>
  .inventory-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0px;
    margin: 3rem auto;
  }

  .slot-link {
    text-decoration: none;
    color: inherit;
  }

  .inventory-slot {
    position: relative;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .slot-bg {
    position: absolute;
    inset: 0;
    width: 72px;
    height: 72px;
    image-rendering: pixelated;
    pointer-events: none;
  }

  .slot-icon {
    position: relative;
    z-index: 1;
    width: 32px;
    height: 32px;
    color: #c8b89a;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.5));
    transition:
      color 150ms ease,
      transform 150ms ease,
      filter 150ms ease;
  }

  .slot-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .custom-svg {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-svg :global(svg) {
    width: 100%;
    height: 100%;
  }

  .custom-svg :global(path) {
    fill: currentColor;
  }

  .slot-label {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(50%);
    z-index: 2;
    background: rgba(0, 0, 0, 0.85);
    color: #e8dcc8;
    font-size: 0.7rem;
    line-height: 1.2;
    padding: 2px 6px;
    border-radius: 3px;
    border: 1px solid rgba(200, 184, 154, 0.3);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 150ms ease;
    font-family: monospace;
  }

  .slot-link:hover .slot-label,
  .slot-link:focus-visible .slot-label,
  .inventory-slot:hover .slot-label {
    opacity: 1;
  }

  .slot-link:hover .slot-icon,
  .slot-link:focus-visible .slot-icon {
    color: #f0d890;
    transform: scale(1.1);
    filter: drop-shadow(0 0 8px rgba(240, 216, 144, 0.4));
  }
</style>
