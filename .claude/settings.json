{
  "permissions": {
    "allow": [
      "Bash(bun run test*)",
      "Bash(bunx vitest run *)",
      "Bash(bun run lint)",
      "Bash(bun run --filter varlock typecheck)",
      "Bash(bun run typecheck*)",
      "Bash(bun run --filter varlock test*)",
      "Bash(bunx tsc --noEmit *)",
      "Bash(bun run lint:fix)",
      "Bash(bun run build*)",
      "Bash(bun run --filter varlock build*)",
      "Bash(bun run repack)",
      "Bash(bun run bumpy:add)",
      "Bash(bunx @varlock/bumpy add*)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/worktree-deps.sh",
            "timeout": 600,
            "statusMessage": "Installing deps + building libs..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/git-push-notice.sh"
          }
        ]
      }
    ]
  }
}
