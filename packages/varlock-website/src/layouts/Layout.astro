---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { Font } from "astro:assets";
import MobileStarDialog from "../components/MobileStarDialog.vue";

interface Props {
  title?: string;
  description?: string;
  showTopBar?: boolean;
  showSearch?: boolean;
  showTableOfContents?: boolean;
  showSidebar?: boolean;
  hideDesktopSidebar?: boolean;
  sidebar?: Array<any>;
  head?: import("../lib/meta").MetaHeadItem[];
}

const {
  title,
  description,
  showTopBar = true,
  showSearch = true,
  showTableOfContents = false,
  showSidebar = false,
  hideDesktopSidebar = false,
  sidebar,
  head,
} = Astro.props;

---

<StarlightPage
  frontmatter={{
    title: title ?? "varlock",
    description: description,
    tableOfContents: showTableOfContents,
    ...(head?.length ? { head } : {}),
  }}
  hasSidebar={showSidebar}
  {...(showSidebar ? { sidebar } : {})}
>
  <slot />
</StarlightPage>

<!-- Mobile star dialog -->
<MobileStarDialog client:load />

<style is:global>
  /* hide the h1 that the starlight page adds */
  .content-panel:first-of-type {
    display: none;
  }

</style>


<!-- // janky but can't use css vars for display -->
{showTopBar ? (
  <style is:global>
    header {
      display: block;
    }
  </style>
) : (
  <style is:global>
  header {
    display: none;
  }

  .main-frame {
    padding-top: 0;
  }
  </style>
)}

{!showSearch ? (
  <style is:global>
    site-search {
      display: none;
    }
  </style>
) : null}

{/*
  Enable Starlight's sidebar (so mobile gets the hamburger nav drawer + search),
  but suppress the desktop sidebar so the page stays full-width like a landing page.
  The mobile overlay (<50rem) is untouched; we only hide the pinned desktop pane.
*/}
{hideDesktopSidebar ? (
  <style is:global>
    @media (min-width: 50rem) {
      .sidebar {
        display: none;
      }
      [data-has-sidebar] {
        --sl-content-inline-start: 0rem;
        --sl-content-width: 75rem;
      }
    }
  </style>
) : null}
