{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@varlock/tsconfig/base.tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    // bun supports .ts imports natively, but tsc needs this
    "allowImportingTsExtensions": true
  },
  "include": ["scripts/**/*.ts"]
}
